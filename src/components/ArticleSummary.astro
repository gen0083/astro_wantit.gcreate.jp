---
import type { CollectionEntry } from "astro:content";
import { getSummary, toParagraphs } from "../util/contents";

interface Props {
  post: CollectionEntry<"post">;
  style?: string;
}

const { post, style = "" }: Props = Astro.props;

const summary = getSummary(post);
const paragraphs = toParagraphs(summary);
---

<div class="flex flex-col">
  {
    paragraphs.map((p) => (
      <p class:list={[style, "text-ms leading-relaxed text-gray-900 px-1 indent-[1em]"]}>
        {p}
      </p>
    ))
  }
</div>
