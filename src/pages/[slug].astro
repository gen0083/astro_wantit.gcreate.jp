---
import {
  getCollectionEntryPost,
  getLinkUrl, getRelatedPostsByTags,
  getSummary,
} from "@/util/contents";
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import fs from "node:fs";
import { getPostTags } from "@/util/tags";
import { getCoverImage } from "@/constants/coverImage";
import { Image } from "astro:assets";
import StarRating from "@/components/StarRating.astro";
import AffiliateLinkParts from "@/components/AffiliateLinkParts.astro";
import { getPostFilePath } from "@/util/github";

export async function getStaticPaths() {
  const allPosts = await getCollectionEntryPost();
  // 日付の降順でソート
  const sortedPosts = allPosts.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );

  return sortedPosts.map((post, index) => {
    const prevPost = index > 0 ? sortedPosts[index - 1] : null;
    const nextPost =
      index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;

    // frontmatterのslugフィールドを優先的に使用、なければpost.slugを使用
    if (!post.data.slug) {
      console.log("slugが指定されていません");
    }
    return {
      params: { slug: post.data.slug || post.id }, // URLになる
      props: { post, prevPost, nextPost },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
const tags = getPostTags(post);
let lastModDate = post.data.lastmod;
if (!lastModDate && post.filePath) {
  const stats = fs.statSync(post.filePath);
  lastModDate = stats.mtime;
}
const imagePath = getCoverImage(post.category);
const summary = getSummary(post);
const related = await getRelatedPostsByTags(post);
---

<BaseLayout
  pageTitle={post.data.title}
  pageDescription={summary}
  layoutType="post"
  {post}
>
  <article class="prose prose-slate max-w-2xl mx-auto card p-8 flex gap-8">
    <header>
      <h1>{post.data.title}</h1>
      <div class="flex flex-row justify-between items-center">
        <ul class="list-none gap-2 text-sm px-0 mx-0">
          <li>
            Posted <time datetime={post.data.date.toISOString()}>
              {
                post.data.date.toLocaleDateString("ja-JP", {
                  year: "numeric",
                  month: "2-digit",
                  day: "2-digit",
                })
              }
            </time>
          </li>

          {
            lastModDate && (
              <li>
                Updated
                <time datetime={lastModDate.toISOString()}>
                  {lastModDate.toLocaleDateString("ja-JP", {
                    year: "numeric",
                    month: "2-digit",
                    day: "2-digit",
                  })}
                </time>
              </li>
            )
          }
        </ul>
        <ul class="flex flex-wrap gap-2 list-none">
          {
            tags?.map((tag) => (
              <li>
                <a
                  href={getLinkUrl(`/tags/${tag.url}`)}
                  class="inline-block px-3 py-1 text-sm font-medium text-slate-700 bg-slate-200 rounded-full no-underline hover:bg-slate-300 transition-colors"
                >
                  {tag.display}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <Image src={imagePath} alt={`${post.category} image`} />
      <div class="border rounded-2xl p-4 flex flex-col gap-4">
        {post.data.product?.name &&
          <div>{post.data.product.name}</div>}
        {post.data.product?.number &&
          <div>{post.data.product.number}</div>}
        {post.data.product?.link &&
          <div><a href={post.data.product.link}>{post.data.product.link}</a></div>}
        <div class="flex flex-row items-center gap-4">
          {
            typeof post.data.product?.rate === "number" && (
              <div class="flex items-center gap-2">
                <StarRating rate={post.data.product.rate}/>
              </div>
            )
          }
          {post.data.product?.comment &&
            <div>{post.data.product.comment}</div>}
        </div>
      </div>
    </header>
    <div>
      <Content />
    </div>
    <div class="mt-8">
      <a
        href={getPostFilePath(post)}
        class="inline-flex items-center justify-center gap-2"
      >
        <img src="/github_logo.svg" alt="GitHub" class="w-5 h-5 m-0" />
        <span>記事の修正リクエストを送る</span>
      </a>
    </div>
    <AffiliateLinkParts post={post} />
    <footer>
      <h2>関連記事</h2>
      {
        related.length == 0 ? (<p>関連記事はありません</p>) : (
          related.map((p) => (
            <li class="list-none"><a href={getLinkUrl(p.id)}>{p.data.title}</a></li>
          ))
        )
      }
    </footer>
  </article>

  <nav class="max-w-2xl mx-auto flex justify-between items-stretch py-8 gap-4">
    <div class="flex-1 flex flex-col text-left">
      {
        prevPost && (
          <a
            href={getLinkUrl(`/${prevPost.data.slug || prevPost.id}`)}
            class="group flex flex-col h-full p-4 border border-slate-200 rounded-lg bg-white hover:bg-slate-50 transition-colors no-underline"
          >
            <span class="text-sm text-slate-500">前の記事</span>
            <span class="block font-bold text-slate-700 mt-1 group-hover:underline">
              {prevPost.data.title}
            </span>
          </a>
        )
      }
    </div>
    <div class="flex-1 flex flex-col text-right">
      {
        nextPost && (
          <a
            href={getLinkUrl(`/${nextPost.data.slug || nextPost.id}`)}
            class="group flex flex-col h-full p-4 border border-slate-200 rounded-lg bg-white hover:bg-slate-50 transition-colors no-underline"
          >
            <span class="text-sm text-slate-500">次の記事</span>
            <span class="block font-bold text-slate-700 mt-1 group-hover:underline">
              {nextPost.data.title}
            </span>
          </a>
        )
      }
    </div>
  </nav>
</BaseLayout>
