---
import { getCoverImage } from "@/constants/coverImage";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { cn } from "../util/cn";
import ArticleSummary from "./ArticleSummary.astro";

interface Props {
  post: CollectionEntry<"post">;
}

const { post } = Astro.props;

const imagePath = getCoverImage("diy");
---
<article
  class={cn(
    "relative group p-4 flex flex-col gap-3",
    "bg-white border border-gray-200 rounded-xl overflow-hidden",
    "shadow-sm hover:shadow-md transition-shadow duration-300",
    "hover:shadow-lg",
  )}
>
  <div class="aspect-video w-full overflow-hidden">
    <Image src={imagePath} alt={`category image`} />
  </div>
  <h2 class="text-xl font-bold leading-tight">
    <a
      href={post.data.slug || post.id}
      class="after:absolute after:inset-0"
    >{post.data.title}</a>
  </h2>
  <ArticleSummary post={post} />
  <footer class="flex">
    <time
      datetime={post.data.date.toISOString()}
      class="text-sm text-gray-500 ml-auto"
    >{post.data.date.toLocaleString("ja-JP")}</time>
  </footer>
</article>
